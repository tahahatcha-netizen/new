<style>
:root {
  --bg-white: #FFFFFF;
  --bg-offwhite: #F5F5F7;
  --bg-dark: #1D1D1F;
  --bg-black: #000000;
  --text-primary: #1D1D1F;
  --text-muted: #86868B;
  --accent-gold: #B8860B;
  --accent-burgundy: #8B0000;
  --glass-bg: rgba(255,255,255,0.72);
  --glass-border: rgba(0,0,0,0.08);
  --glass-blur: blur(20px);
  --font: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'SF Pro Text', 'Helvetica Neue', sans-serif;
  --max-width: 980px;
  --nav-height: 52px;
}
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; }
body { font-family: var(--font); color: var(--text-primary); background: var(--bg-white); -webkit-font-smoothing: antialiased; overflow-x: hidden; }
a { text-decoration: none; color: inherit; }
button { font-family: var(--font); cursor: pointer; border: none; outline: none; }
.container { max-width: var(--max-width); margin: 0 auto; padding: 0 24px; }
.eyebrow { font-size: 0.8rem; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 12px; }
.section-headline { font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 600; letter-spacing: -0.02em; line-height: 1.15; margin-bottom: 24px; }
.section-headline em { font-style: italic; }
.fade-in { opacity: 0; transform: translateY(60px); }
.btn-primary { display: inline-flex; align-items: center; justify-content: center; padding: 14px 32px; background: var(--bg-white); color: var(--bg-dark); font-size: 1rem; font-weight: 500; border-radius: 980px; transition: all 0.3s ease; }
.btn-primary:hover { transform: scale(1.04); }
.btn-ghost { display: inline-flex; align-items: center; justify-content: center; padding: 14px 32px; background: transparent; color: var(--bg-white); font-size: 1rem; font-weight: 500; border: 1.5px solid rgba(255,255,255,0.5); border-radius: 980px; transition: all 0.3s ease; }
.btn-ghost:hover { border-color: #fff; background: rgba(255,255,255,0.08); }
.btn-ghost-dark { display: inline-flex; align-items: center; justify-content: center; padding: 14px 32px; background: transparent; color: #fff; font-size: 1rem; font-weight: 500; border: 1.5px solid rgba(255,255,255,0.4); border-radius: 980px; transition: all 0.3s ease; }
.btn-ghost-dark:hover { border-color: #fff; background: rgba(255,255,255,0.1); }

/* NAV */
nav { position: fixed; top: 0; left: 0; right: 0; height: var(--nav-height); z-index: 1000; transition: all 0.4s ease; }
nav.scrolled { background: var(--glass-bg); -webkit-backdrop-filter: var(--glass-blur); backdrop-filter: var(--glass-blur); border-bottom: 1px solid var(--glass-border); }
nav .nav-inner { max-width: var(--max-width); margin: 0 auto; padding: 0 24px; height: 100%; display: flex; align-items: center; justify-content: space-between; }
.nav-logo { font-size: 1.15rem; font-weight: 700; letter-spacing: -0.02em; color: #fff; transition: color 0.3s; }
nav.scrolled .nav-logo { color: var(--text-primary); }
.nav-links { display: flex; gap: 28px; list-style: none; }
.nav-links a { font-size: 0.82rem; font-weight: 400; color: rgba(255,255,255,0.85); transition: color 0.3s; }
nav.scrolled .nav-links a { color: var(--text-primary); }
.nav-links a:hover { color: var(--accent-gold); }
.hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; padding: 4px; }
.hamburger span { display: block; width: 20px; height: 1.5px; background: #fff; transition: all 0.3s; }
nav.scrolled .hamburger span { background: var(--text-primary); }
.mobile-menu { display: none; position: fixed; top: var(--nav-height); left: 0; right: 0; background: var(--glass-bg); -webkit-backdrop-filter: var(--glass-blur); backdrop-filter: var(--glass-blur); padding: 20px 24px; z-index: 999; border-bottom: 1px solid var(--glass-border); }
.mobile-menu.open { display: block; }
.mobile-menu a { display: block; padding: 12px 0; font-size: 1rem; color: var(--text-primary); border-bottom: 1px solid rgba(0,0,0,0.06); }

/* HERO */
#hero { position: relative; height: 100vh; min-height: 600px; background: #000; display: flex; align-items: center; justify-content: center; overflow: hidden; }
#hero canvas { position: absolute; top: 0; left: 0; width: 100%; height: 100%; }
.hero-glow { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 600px; height: 600px; background: radial-gradient(circle, rgba(184,134,11,0.08) 0%, transparent 70%); pointer-events: none; }
.hero-content { position: relative; z-index: 2; text-align: center; color: #fff; padding: 0 24px; }
.hero-eyebrow { font-size: 0.85rem; font-weight: 500; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(255,255,255,0.5); margin-bottom: 20px; }
.hero-headline { font-size: clamp(3rem, 8vw, 6rem); font-weight: 700; letter-spacing: -0.03em; line-height: 1.05; margin-bottom: 20px; }
.hero-subtitle { font-size: 1.15rem; font-weight: 400; color: rgba(255,255,255,0.55); line-height: 1.6; max-width: 600px; margin: 0 auto 36px; }
.hero-buttons { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
.scroll-indicator { position: absolute; bottom: 40px; left: 50%; transform: translateX(-50%); z-index: 2; }
.scroll-indicator svg { animation: scrollBounce 2s infinite; }
@keyframes scrollBounce { 0%,100% { transform: translateY(0); opacity: 0.5; } 50% { transform: translateY(8px); opacity: 1; } }

/* MISSION */
#mission { padding: 120px 0; background: var(--bg-white); }
.mission-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
.mission-text p { font-size: 1.1rem; line-height: 1.7; color: var(--text-primary); margin-bottom: 20px; }
.mission-text p.muted { color: var(--text-muted); }
.mission-visual { display: flex; align-items: center; justify-content: center; }
.mission-circle { width: 320px; height: 320px; border-radius: 50%; background: conic-gradient(from 180deg, rgba(184,134,11,0.12), rgba(139,0,0,0.06), rgba(184,134,11,0.12)); position: relative; }
.mission-circle::after { content: ''; position: absolute; inset: 40px; border-radius: 50%; background: var(--bg-white); }

/* IMPACT */
#impact { padding: 120px 0; background: var(--bg-offwhite); }
.impact-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 40px; text-align: center; }
.impact-number { font-size: clamp(3rem, 7vw, 5rem); font-weight: 700; letter-spacing: -0.03em; color: var(--text-primary); line-height: 1; margin-bottom: 8px; }
.impact-number span { font-size: 0.6em; }
.impact-label { font-size: 1rem; color: var(--text-muted); font-weight: 400; }

/* PILLARS */
#pillars { padding: 120px 0; background: var(--bg-white); }
.pillars-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px; }
.pillar-card { background: var(--glass-bg); -webkit-backdrop-filter: var(--glass-blur); backdrop-filter: var(--glass-blur); border: 1px solid var(--glass-border); border-radius: 20px; padding: 48px 36px; text-align: center; transition: all 0.4s ease; cursor: default; }
.pillar-card:hover { transform: translateY(-8px); box-shadow: 0 20px 60px rgba(0,0,0,0.08); }
.pillar-icon { font-size: 3rem; margin-bottom: 20px; }
.pillar-card h3 { font-size: 1.4rem; font-weight: 600; margin-bottom: 12px; }
.pillar-card p { font-size: 1rem; color: var(--text-muted); line-height: 1.6; }

/* PROGRAMS */
#programs { padding: 120px 0; background: var(--bg-offwhite); }
.events-scroll { display: flex; gap: 24px; overflow-x: auto; scroll-snap-type: x mandatory; padding: 20px 0 40px; -webkit-overflow-scrolling: touch; scrollbar-width: none; }
.events-scroll::-webkit-scrollbar { display: none; }
.event-card { flex: 0 0 320px; scroll-snap-align: start; background: var(--glass-bg); -webkit-backdrop-filter: var(--glass-blur); backdrop-filter: var(--glass-blur); border: 1px solid var(--glass-border); border-radius: 20px; padding: 36px 28px; transition: all 0.3s ease; }
.event-card:hover { transform: translateY(-6px); box-shadow: 0 16px 48px rgba(0,0,0,0.07); }
.event-date { display: inline-block; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; color: var(--accent-gold); background: rgba(184,134,11,0.08); padding: 6px 14px; border-radius: 980px; margin-bottom: 16px; }
.event-card h3 { font-size: 1.25rem; font-weight: 600; margin-bottom: 10px; }
.event-card p { font-size: 0.95rem; color: var(--text-muted); line-height: 1.6; margin-bottom: 14px; }
.event-location { font-size: 0.82rem; color: var(--text-muted); display: flex; align-items: center; gap: 6px; }

/* MENTORING */
#mentoring { padding: 140px 0; background: var(--bg-dark); color: #fff; text-align: center; }
.mentoring-number { font-size: clamp(5rem, 15vw, 10rem); font-weight: 700; letter-spacing: -0.04em; line-height: 1; color: rgba(255,255,255,0.06); margin-bottom: -40px; }
.mentoring-headline { font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 600; letter-spacing: -0.02em; line-height: 1.2; margin-bottom: 24px; }
.mentoring-headline em { font-style: italic; }
.mentoring-desc { font-size: 1.15rem; color: rgba(255,255,255,0.55); line-height: 1.7; max-width: 560px; margin: 0 auto 36px; }

/* TESTIMONIALS */
#testimonials { padding: 120px 0; background: var(--bg-white); }
.testimonials-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px; }
.testimonial-card { background: var(--glass-bg); -webkit-backdrop-filter: var(--glass-blur); backdrop-filter: var(--glass-blur); border: 1px solid var(--glass-border); border-radius: 20px; padding: 40px 32px; position: relative; }
.testimonial-card::before { content: '\201C'; position: absolute; top: 20px; left: 28px; font-size: 4rem; color: rgba(184,134,11,0.12); font-family: Georgia, serif; line-height: 1; }
.testimonial-card blockquote { font-size: 1.05rem; font-style: italic; line-height: 1.7; color: var(--text-primary); margin-bottom: 20px; padding-top: 20px; }
.testimonial-author { font-size: 0.95rem; font-weight: 600; }
.testimonial-role { font-size: 0.85rem; color: var(--text-muted); }
.testimonial-stars { margin-bottom: 14px; color: var(--accent-gold); font-size: 0.9rem; letter-spacing: 2px; }

/* PARTNERS */
#partners { padding: 100px 0; background: var(--bg-offwhite); }
.partners-grid { display: flex; justify-content: center; gap: 48px; flex-wrap: wrap; }
.partner-item { font-size: 1.1rem; font-weight: 500; color: rgba(0,0,0,0.15); letter-spacing: 0.05em; transition: color 0.3s; padding: 16px 24px; }
.partner-item:hover { color: rgba(0,0,0,0.5); }

/* CTA */
#cta { padding: 160px 0; background: var(--bg-dark); color: #fff; text-align: center; position: relative; overflow: hidden; }
.cta-glow { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 600px; height: 600px; background: radial-gradient(circle, rgba(184,134,11,0.06) 0%, transparent 70%); pointer-events: none; }
.cta-headline { font-size: clamp(2.5rem, 6vw, 4.5rem); font-weight: 700; letter-spacing: -0.03em; line-height: 1.1; margin-bottom: 20px; position: relative; }
.cta-headline em { font-style: italic; }
.cta-subtitle { font-size: 1.15rem; color: rgba(255,255,255,0.55); line-height: 1.6; max-width: 520px; margin: 0 auto 40px; position: relative; }
.cta-buttons { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; position: relative; }

/* FOOTER */
footer { background: var(--bg-black); color: rgba(255,255,255,0.5); padding: 80px 0 40px; }
.footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 40px; margin-bottom: 60px; }
.footer-brand p { font-size: 0.95rem; line-height: 1.7; margin-top: 16px; max-width: 280px; }
.footer-col h4 { font-size: 0.85rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(255,255,255,0.8); margin-bottom: 16px; }
.footer-col ul { list-style: none; }
.footer-col li { margin-bottom: 10px; }
.footer-col a { font-size: 0.9rem; color: rgba(255,255,255,0.45); transition: color 0.3s; }
.footer-col a:hover { color: #fff; }
.footer-logo { font-size: 1.2rem; font-weight: 700; color: #fff; }
.footer-social { display: flex; gap: 16px; margin-top: 20px; }
.footer-social a { display: flex; align-items: center; justify-content: center; width: 36px; height: 36px; border-radius: 50%; border: 1px solid rgba(255,255,255,0.12); color: rgba(255,255,255,0.5); font-size: 0.85rem; transition: all 0.3s; }
.footer-social a:hover { border-color: rgba(255,255,255,0.4); color: #fff; }
.footer-bottom { border-top: 1px solid rgba(255,255,255,0.06); padding-top: 28px; text-align: center; font-size: 0.82rem; }

/* RESPONSIVE */
@media (max-width: 768px) {
  .nav-links { display: none; }
  .hamburger { display: flex; }
  .mission-grid { grid-template-columns: 1fr; gap: 40px; }
  .mission-visual { order: -1; }
  .mission-circle { width: 220px; height: 220px; }
  .impact-grid { grid-template-columns: repeat(2, 1fr); gap: 32px; }
  .pillars-grid { grid-template-columns: 1fr; max-width: 400px; margin: 0 auto; }
  .testimonials-grid { grid-template-columns: 1fr; max-width: 480px; margin: 0 auto; }
  .footer-grid { grid-template-columns: 1fr 1fr; }
  .hero-headline br { display: none; }
  .event-card { flex: 0 0 280px; }
  .partner-item { font-size: 0.95rem; }
}
@media (max-width: 480px) {
  .impact-grid { grid-template-columns: 1fr; }
  .footer-grid { grid-template-columns: 1fr; }
  .hero-buttons { flex-direction: column; align-items: center; }
  .cta-buttons { flex-direction: column; align-items: center; }
}
</style>
</head>
